NODE_ENV=development
PORT=3000

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=rediss://default:[password]@[host].upstash.io:6380

# Auth
JWT_SECRET=minimum-32-character-secret-here
JWT_EXPIRES_IN=7d

# Gemini
GEMINI_API_KEY=

# Meta WhatsApp
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
# Set to "true" in production to require a valid Meta X-Hub-Signature-256 on
# inbound webhook POSTs (rejects forged/unsigned traffic). Leave "false" for
# local testing with the unsigned test-whatsapp.sh script.
WEBHOOK_VERIFY_SIGNATURE=false

# Brevo transactional email (HTTP API — Railway blocks outbound SMTP).
# Get BREVO_API_KEY from Settings > SMTP & API > API Keys.
# FROM_EMAIL must be verified in Settings > Senders & IP > Add a sender.
BREVO_API_KEY=
FROM_EMAIL=youraddress@example.com
FROM_NAME=Zero Clinic OS

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Frontend
FRONTEND_URL=https://zero-kappa-mocha.vercel.app

# Internal job runner protection
JOB_SECRET=minimum-16-characters
